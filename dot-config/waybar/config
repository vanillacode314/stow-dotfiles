[{
    // vim: ft=jsonc
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    "output": "HDMI-A-1",
    // "width": 1280, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "hyprland/submap", "hyprland/window"],
    "modules-center": [],
    "modules-right": ["mpris", "idle_inhibitor", "pulseaudio", "network", "battery", "clock", "tray"],
    "hyprland/window": {
        "format": "{}",
        "rewrite": {
             "(.*) вҖ” .* вҖ” Zen Browser": "рҹҢҺ $1",
            "(.*) - Youtube вҖ” .* вҖ” Zen Browser": "Youtube",
             "(.*) - Helium": "рҹҢҺ $1",
            "(.*) - Youtube - Helium": "Youtube"
        },
        "separate-outputs": true
    },
    // Modules configuration
    // "hyprland/workspaces": {
    //     "disable-scroll": true,
    //     "all-outputs": true,
    //     "warp-on-scroll": false,
    //     "format": "{name}: {icon}",
    //     "format-icons": {
    //         "1": "п„ ",
    //         "2": "пүЁ",
    //         "3": "п„Ў",
    //         "4": "пҶј",
    //         "5": "пҒө",
    //         "urgent": "пҒӘ",
    //         "focused": "пҶ’",
    //         "default": "п„‘"
    //     }
    // },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пҖЈ",
            "unlocked": "пӮң"
        }
    },
    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "hyprland/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "пӢ’"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpris": {
      "interval": 2,
      "format": "{player_icon} {title} - {artist} ",
      "format-paused": "{status_icon} <i>{title} - {artist}</i> ",
      "player-icons": {
        "default": "в–¶",
        "mpv": "рҹҺө"
      },
      "status-icons": {
        "paused": "вҸё"
      }
    },
    "mpd": {
        "format": "{stateIcon} {artist}/{title}",
        "format-disconnected": "Disconnected пҖҒ ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пҖҒ ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "пғ„ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пҒҙ</span> ",
            "on": "пҒҙ "
        },
        "repeat-icons": {
            "on": "пҖһ "
        },
        "single-icons": {
            "on": "пҖһ1"
        },
        "state-icons": {
            "paused": "пҒҢ ",
            "playing": "пҒӢ "
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click-right": "pypr toggle music",
        "on-click": "playerctl -p mpd play-pause",
        "on-scroll-up": "playerctl -p mpd volume 0.05+",
        "on-scroll-down": "playerctl -p mpd volume 0.05-"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пҒ® ",
            "deactivated": "пҒ° "
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%I:%M %p}",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% пӢӣ ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пғү "
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}В°C {icon}",
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пқ«", "пӢү", "пқ©"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§ ",
        "format-plugged": "{capacity}% пҮҰ ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["пү„ ", "пүғ ", "пүӮ ", "пүҒ ", "пүҖ "]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "interval": 5,
        // "interface": "wlan0", // (Optional) To force the use of this interface
        "format-wifi": "пҒў {bandwidthUpBytes} пҒЈ {bandwidthDownBytes} пҮ« ",
        // "format-ethernet": "{ipaddr}/{cidr} пһ– ",
        "format-ethernet": "пҒў {bandwidthUpBytes} пҒЈ {bandwidthDownBytes} пҮ« ",
        "tooltip-format": "{ifname} via {gwaddr} пһ– ",
        "format-linked": "{ifname} (No IP) пһ– ",
        "format-disconnected": "Disconnected вҡ  ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}пҠ” {format_source}",
        "format-bluetooth-muted": "пҡ© {icon}пҠ” {format_source}",
        "format-muted": "пҡ© {format_source}",
        "format-source": "{volume}% п„° ",
        "format-source-muted": "п„ұ ",
        "format-icons": {
            "headphone": "пҖҘ ",
            "hands-free": "п–җ ",
            "headset": "п–җ ",
            "phone": "пӮ• ",
            "portable": "пӮ• ",
            "car": "пҶ№ ",
            "default": ["пҖҰ ", "пҖ§ ", "пҖЁ "]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "пҶј ",
            "default": "рҹҺң "
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
},
