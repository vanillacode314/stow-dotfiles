        "format": "{}",
        "rewrite": {
            // "(.*) вАФ Zen Browser": "рЯМО $1",
             "(.*) вАФ .* вАФ Personal вАФ Zen Browser": "рЯМО $1",
            "(.*) - Youtube вАФ .* вАФ Zen Browser": "Youtube"
