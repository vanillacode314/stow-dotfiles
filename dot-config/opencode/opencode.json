{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "sort": "allow",
      "wc *": "allow",
      "pwd": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "provider": {},
  "model": "opencode/minimax-m2.5-free",
  "small_model": "opencode/minimax-m2.5-free"
}
